@using HsoPkipt.ViewModels.Home
@model HomeIndexVM

@{
    ViewData["Title"] = "Главная страница";
}

<main class="home">
    <div class="__container">

        <!-- Баннер -->
        <section class="hero" data-animate>
            <div class="banner">
                <div class="img">
                    <div class="hero-badge">ШСО ПКИПТ</div>
                    <h1 class="title">Вступай в лучшие объединения города!</h1>
                    <p class="hero-subtitle">
                        Команда, опыт, реальные проекты и студенческая жизнь,
                        в которой хочется участвовать.
                    </p>
                </div>

                <div class="hero-side">
                    <button class="btn" type="button" data-fn="modal__join-us">
                        Подать заявку
                    </button>

                    <div class="hero-mini-stats">
                        <div class="mini-stat">
                            <span class="value">2016</span>
                            <span class="label">год основания</span>
                        </div>
                        <div class="mini-stat">
                            <span class="value">4</span>
                            <span class="label">направления</span>
                        </div>
                        <div class="mini-stat">
                            <span class="value">200+</span>
                            <span class="label">участников</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Описание -->
        <section class="intro-section" data-animate>
            <h2 class="section-title">О движении</h2>
            <div class="description-card">
                <p class="description">
                    Студенческие отряды ИТ–колледжа начались с педагогического отряда «Созвездие»,
                    появившегося 26 января 2016 года. За это время через движение прошли сотни
                    студентов — каждый нашёл здесь команду, опыт и первую настоящую работу.
                </p>
            </div>
        </section>

        <!-- Слайдер новостей -->
        <section class="slider-section" data-animate>
            <h2 class="section-title">Последние новости</h2>

            <div class="news-block slider-block" data-slider>
                <div class="news-loader" data-slider-loader>
                    <div class="spinner"></div>
                    <p>Загрузка новостей…</p>
                </div>

                <button class="arrow-controller prev" type="button" data-slider-prev>‹</button>

                <div class="wrapper-slide hidden" data-slider-wrapper>
                    <div class="track" data-slider-track>
                        @if (Model?.LatestNews != null && Model.LatestNews.Any())
                        {
                            foreach (var news in Model.LatestNews)
                            {
                                <a href="@Url.Action("NewsDetails", "Home", new { id = news.Id })" class="card-news">
                                    <img src="@(news.ImageUrl ?? Url.Content("~/assets/img/foto_2.png"))" alt="@news.Title">
                                    <p class="title">@news.Title</p>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="card-news err">
                                <img src="~/assets/icon/err.no-load.svg" alt="Нет новостей">
                                <p class="title">Скоро здесь появятся новости</p>
                            </div>
                            <div class="card-news err">
                                <img src="~/assets/icon/err.no-load.svg" alt="Следите за обновлениями">
                                <p class="title">Следите за обновлениями</p>
                            </div>
                        }
                    </div>
                </div>

                <button class="arrow-controller next" type="button" data-slider-next>›</button>
            </div>
        </section>

        <!-- Секция: Направления -->
        <section class="directions" data-animate>
            <h2 class="section-title">Наши направления</h2>
            <div class="directions-grid">
                <div class="direction-card">
                    <h3 class="direction-name">Педагогический</h3>
                    <p class="direction-desc">Работа в детских лагерях и образовательных учреждениях. Первый опыт наставничества.</p>
                </div>
                <div class="direction-card">
                    <h3 class="direction-name">IT-отряд</h3>
                    <p class="direction-desc">Разработка, поддержка и цифровизация — применяем знания на реальных проектах.</p>
                </div>
                <div class="direction-card">
                    <h3 class="direction-name">Сервисный</h3>
                    <p class="direction-desc">Волонтёрство, организация мероприятий и работа с населением города.</p>
                </div>
                <div class="direction-card">
                    <h3 class="direction-name">Строительный</h3>
                    <p class="direction-desc">Участие в благоустройстве и строительных проектах на территории региона.</p>
                </div>
            </div>
        </section>

        <!-- Слайдер проектов -->
        <section class="slider-section" data-animate>
            <h2 class="section-title">Последние проекты</h2>

            <div class="news-block slider-block" data-slider>
                <div class="news-loader" data-slider-loader>
                    <div class="spinner"></div>
                    <p>Загрузка проектов…</p>
                </div>

                <button class="arrow-controller prev" type="button" data-slider-prev>‹</button>

                <div class="wrapper-slide hidden" data-slider-wrapper>
                    <div class="track" data-slider-track>
                        @if (Model?.LatestProjects != null && Model.LatestProjects.Any())
                        {
                            foreach (var project in Model.LatestProjects)
                            {
                                <a href="@Url.Action("Details", "Projects", new { id = project.Id })" class="card-news">
                                    <img src="@(project.ImageUrl ?? Url.Content("~/assets/img/foto_2.png"))" alt="@project.Title">
                                    <p class="title">@project.Title</p>
                                </a>
                            }
                        }
                        else
                        {
                            <div class="card-news err">
                                <img src="~/assets/icon/err.no-load.svg" alt="Нет проектов">
                                <p class="title">Скоро здесь появятся проекты</p>
                            </div>
                            <div class="card-news err">
                                <img src="~/assets/icon/err.no-load.svg" alt="Следите за обновлениями">
                                <p class="title">Следите за обновлениями</p>
                            </div>
                        }
                    </div>
                </div>

                <button class="arrow-controller next" type="button" data-slider-next>›</button>
            </div>
        </section>

        <!-- Секция: Стать частью -->
        <section class="join-section" data-animate>
            <div class="join-content">
                <div class="join-text">
                    <h3 class="join-title">Стань частью команды</h3>
                    <p class="join-desc">
                        Студенческий отряд — это не просто подработка. Это первый трудовой опыт,
                        настоящие друзья и возможность изменить жизнь вокруг себя.
                        Присоединяйся — двери открыты для каждого студента колледжа.
                    </p>
                    <button type="button" class="join-btn" data-fn="modal__join-us">
                        Вступить в отряд
                    </button>
                </div>

                <div class="join-stats">
                    <div class="stat">
                        <span class="stat-number">2016</span>
                        <span class="stat-label">Год основания</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">4</span>
                        <span class="stat-label">Направления</span>
                    </div>
                    <div class="stat">
                        <span class="stat-number">200+</span>
                        <span class="stat-label">Бойцов за всё время</span>
                    </div>
                </div>
            </div>
        </section>

    </div>
</main>

@section Scripts {
    <script src="@(Url.Content("~/js/effect/home.index.js"))"></script>
}