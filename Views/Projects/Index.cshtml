@using HsoPkipt.ViewModels.Projects
@model ProjectsVM

@{
    ViewData["Title"] = "Наши проекты";
}

<main class="project-page">
    <div class="project-container">
        <h2 class="project-title">Наши проекты</h2>

        <div class="project-grid" id="projectsGrid">
            @if (Model.ProjectItems.Any())
            {
                foreach (var project in Model.ProjectItems)
                {
                    var hasTitle = !string.IsNullOrWhiteSpace(project.Title);
                    var hasDescription = !string.IsNullOrWhiteSpace(project.ShortDescription);
                    var hasImage = !string.IsNullOrWhiteSpace(project.ImageUrl);

                    var cardClass = "card-project";

                    if (!hasTitle && !hasDescription)
                    {
                        cardClass += " no-content";
                    }
                    else if (!hasImage)
                    {
                        cardClass += " no-image";
                    }

                    <div class="@cardClass" data-project-id="@project.Id">
                        <img src="@(hasImage? project.ImageUrl: Url.Content("~/assets/icon/err.no-image.svg"))"
                             alt="@(hasTitle? project.Title: "Проект")" />
                        <div class="card-text-wrapper">
                            @if (hasTitle)
                            {
                                <p class="card-title">@project.Title</p>
                            }
                            @if (hasDescription)
                            {
                                <p class="card-description">@project.ShortDescription</p>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="card-project not-load">
                    <img src="~/assets/icon/err.no-load.svg" alt="" />
                    <div class="card-text-wrapper"></div>
                </div>
                <div class="card-project not-load">
                    <img src="~/assets/icon/err.no-load.svg" alt="" />
                    <div class="card-text-wrapper"></div>
                </div>
            }
        </div>

        <div class="load-more-container" id="loadMoreContainer">
            <button class="btn-load-more" id="btnLoadMore" type="button">
                Показать ещё
                <span class="loading-spinner hidden" id="loadingSpinner"></span>
            </button>
        </div>
    </div>
</main>

@section Scripts {
    <script>
            window.projectsPage = {
                currentPage: @Model.PageNumber,
                totalPages: @Model.TotalPages
            };
    </script>
    <script src="~/js/app/projects.index.js"></script>
}