@model HsoPkipt.ViewModels.Project.ProjectDetailsVM

@{
    ViewData["Title"] = Model.Title;
    var culture = new System.Globalization.CultureInfo("ru-RU");
    bool wasUpdated = Model.UpdatedAt > Model.CreatedAt.AddMinutes(1);
}

<main class="project-details">
    <div class="project-details__container">

        <!-- Назад -->
        <a asp-controller="Projects" asp-action="Index" class="project-details__back">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"         stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <polyline points="19 12 5 12" />
                <polyline points="12 19 5 12 12 5" />
            </svg>
            Назад к проектам
        </a>

        <article class="project-details__article">

            <!-- Шапка -->
            <header class="project-details__header">
                <div class="project-details__meta">
                    <span class="project-details__meta-item">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                            <line x1="16" y1="2" x2="16" y2="6" />
                            <line x1="8" y1="2" x2="8" y2="6" />
                            <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                        @Model.CreatedAt.ToString("dd MMMM yyyy", culture)
                    </span>
                    @if (wasUpdated)
                    {
                        <span class="project-details__meta-sep">·</span>
                        <span class="project-details__meta-item project-details__meta-item--updated">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="23 4 23 10 17 10" />
                                <path d="M20.49 15a9 9 0 11-2.12-9.36L23 10" />
                            </svg>
                            Обновлено @Model.UpdatedAt.ToString("dd MMMM yyyy", culture)
                        </span>
                    }
                </div>

                <h1 class="project-details__title">@Model.Title</h1>

                @if (!string.IsNullOrWhiteSpace(Model.ShortDescription))
                {
                    <p class="project-details__lead">@Model.ShortDescription</p>
                }
            </header>

            <!-- Изображение -->
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <div class="project-details__image-wrap" data-zoom>
                    <img src="@Model.ImageUrl"   alt="@Model.Title"       class="project-details__image" />
                    <span class="project-details__zoom-hint">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"                        stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="11" cy="11" r="8" />
                            <line x1="21" y1="21" x2="16.65" y2="16.65" />
                            <line x1="11" y1="8" x2="11" y2="14" />
                            <line x1="8" y1="11" x2="14" y2="11" />
                        </svg>
                    </span>
                </div>
            }

            <!-- Контент -->
            <div class="project-details__content">
                @Html.Raw(Model.Content)
            </div>

        </article>

    </div>
</main>

<!-- Лайтбокс -->
<div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="lightbox__close" id="lightboxClose" aria-label="Закрыть">&#10005;</button>
    <div class="lightbox__backdrop" id="lightboxBackdrop"></div>
    <div class="lightbox__inner">
        <img src="" alt="" class="lightbox__img" id="lightboxImg" />
    </div>
</div>

@section Scripts {
    <script src="~/js/app/projects.details.js"></script>
}