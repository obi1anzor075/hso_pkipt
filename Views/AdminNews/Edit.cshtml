@model HsoPkipt.ViewModels.News.UpdateNewsItemVM

@{
    ViewData["Title"] = "Редактирование новости";
}

<h1>Редактирование новости</h1>

<p>
    <a asp-action="Index">Назад к списку</a>
</p>

<form method="post">
    @Html.AntiForgeryToken()

    <div>
        <label asp-for="Title"></label>
        <input asp-for="Title" />
        <span asp-validation-for="Title"></span>
    </div>

    <div>
        <label asp-for="ShortDescription"></label>
        <textarea asp-for="ShortDescription"></textarea>
        <span asp-validation-for="ShortDescription"></span>
    </div>

    <div>
        <label asp-for="Content"></label>
        <textarea asp-for="Content"></textarea>
        <span asp-validation-for="Content"></span>
    </div>

    <div>
        <label asp-for="ImageUrl"></label>
        <input asp-for="ImageUrl" />
        <span asp-validation-for="ImageUrl"></span>
    </div>

    <div>
        <label asp-for="IsPublished"></label>
        <input asp-for="IsPublished" type="checkbox" />
        <span asp-validation-for="IsPublished"></span>
    </div>

    <button type="submit">Сохранить</button>
</form>