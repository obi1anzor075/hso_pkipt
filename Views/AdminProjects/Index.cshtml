@using System.Globalization
@model HsoPkipt.Common.PagedResult<HsoPkipt.ViewModels.Project.ProjectItemVM>

@{
    ViewData["Title"] = "Список проектов";
}

<main class="admin-page">
    <div class="admin-page__inner">

        <!-- Шапка -->
        <div class="admin-header admin-fade-in">
            <div class="admin-header__left">
                <a asp-controller="Admin" asp-action="Projects" class="admin-header__back">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                    Управление проектами
                </a>
                <h1 class="admin-header__title">Все проекты</h1>
                <p class="admin-header__subtitle">Страница @Model.CurrentPage из @Model.TotalPages</p>
            </div>
            <a asp-action="Create" class="admin-header__action">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line style="color: white;" x1="12" y1="5" x2="12" y2="19"/>
                    <line style="color: white;" x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Создать проект
            </a>
        </div>

        <div class="admin-divider"></div>

        @if (Model.Items == null || !Model.Items.Any())
        {
            <div class="admin-news-table-wrap admin-fade-in">
                <div class="admin-news-empty">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                        <line x1="8" y1="21" x2="16" y2="21"/>
                        <line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                    <p>Проектов пока нет</p>
                </div>
            </div>
        }
        else
        {
            <div class="admin-news-toolbar admin-fade-in">
                <p class="admin-news-count">
                    Показано <strong>@Model.Items.Count()</strong> записей
                </p>
            </div>

            <div class="admin-news-table-wrap admin-fade-in" style="animation-delay:0.08s">
                <table class="admin-news-table">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Дата</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="admin-news-table__title">@item.Title</div>
                                    @if (!string.IsNullOrEmpty(item.ShortDescription))
                                    {
                                        <div class="admin-news-table__desc">@item.ShortDescription</div>
                                    }
                                </td>
                                <td>
                                    <span class="admin-news-table__date">
                                        @item.CreatedAt.ToString("dd.MM.yyyy", CultureInfo.InvariantCulture)
                                    </span>
                                </td>
                                <td>
                                    <div class="admin-news-table__actions">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="admin-tbl-btn admin-tbl-btn--edit">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/>
                                                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/>
                                            </svg>
                                            Изменить
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="admin-tbl-btn admin-tbl-btn--delete">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="3 6 5 6 21 6"/>
                                                <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
                                                <path d="M10 11v6M14 11v6"/>
                                                <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
                                            </svg>
                                            Удалить
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="admin-pagination admin-fade-in" style="animation-delay:0.12s">
                    @if (Model.CurrentPage > 1)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"
                           class="admin-pagination__btn">‹</a>
                    }
                    else
                    {
                        <span class="admin-pagination__btn disabled">‹</span>
                    }

                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <a asp-action="Index" asp-route-page="@p"
                           class="admin-pagination__btn @(p == Model.CurrentPage ? "active" : "")">@p</a>
                    }

                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"
                           class="admin-pagination__btn">›</a>
                    }
                    else
                    {
                        <span class="admin-pagination__btn disabled">›</span>
                    }
                </div>
            }
        }

    </div>
</main>