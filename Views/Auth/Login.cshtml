@model HsoPkipt.ViewModels.LoginVM;
@{
    ViewData["Title"] = "Вход";
}
<main class="auth">
  <div class="wrapper">
    <div class="wrapper__body">

      <div class="description">
        <h2>Авторизация</h2>
      </div>

      <form asp-action="Login" asp-controller="Auth" method="post" class="form_component">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="error_message_form"></div>

        <div class="input-block">

          <div class="email-block">
            <label asp-for="Email">Электронная почта</label>
            <input asp-for="Email" id="email" type="email" required autocomplete="email" />
            <span asp-validation-for="Email"></span>
          </div>

          <div class="password-block">
            <div class="password label">
              <label asp-for="Password">Пароль</label>
              <a class="forgot" href="#">Забыли пароль?</a>
            </div>
            <div class="password input">
              <input data-inc="password" asp-for="Password" id="password" type="password" required minlength="8"
                     autocomplete="current-password" />
              <button class="eye close" data-fn="visible__password" type="button"></button>
            </div>
            <span asp-validation-for="Password"></span>
          </div>

          <div class="checkbox_rm-block">
            <label asp-for="RememberMe">
              <input asp-for="RememberMe" type="checkbox" />
              <span>Запомнить меня</span>
            </label>
          </div>

        </div>

        <button type="submit" class="submit">Войти</button>

        <div class="register">
          <h3>Хочешь вступить в отряды? <a href="#">Тебе сюда!</a></h3>
        </div>
      </form>

    </div>
  </div>
</main>

@section Scripts {
  <script src="~/js/effect/auth.login.js"></script>
}