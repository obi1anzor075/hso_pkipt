@{
    ViewData["Title"] = "Управление пользователями";
}

<main class="admin-page">
    <div class="admin-page__inner">

        <!-- Шапка -->
        <div class="admin-header admin-fade-in">
            <div class="admin-header__left">
                <a asp-controller="Admin" asp-action="Index" class="admin-header__back">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                    Панель управления
                </a>
                <h1 class="admin-header__title">Пользователи</h1>
                <p class="admin-header__subtitle">Управление учётными записями и ролями</p>
            </div>
            <a asp-controller="AdminUser" asp-action="Create" class="admin-header__action">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line style="color: white;" x1="12" y1="5" x2="12" y2="19"/>
                    <line style="color: white;" x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Создать пользователя
            </a>
        </div>

        <div class="admin-divider"></div>

        <!-- Действия -->
        <div class="admin-actions">
            <a asp-controller="AdminUser" asp-action="Index" class="admin-action-item admin-fade-in">
                <div class="admin-action-item__icon-wrap">
                    <span class="admin-action-item__icon" style="mask-image:url(/assets/icon/news.svg)"></span>
                </div>
                <div class="admin-action-item__text">
                    <span class="admin-action-item__title">Список всех пользователей</span>
                    <span class="admin-action-item__hint">Просмотр, редактирование и удаление пользователей</span>
                </div>
                <span class="admin-action-item__chevron"></span>
            </a>
            
            <a asp-controller="AdminUser" asp-action="Create" class="admin-action-item admin-fade-in">
                <div class="admin-action-item__icon-wrap">
                    <span class="admin-action-item__icon" style="mask-image:url(/assets/icon/create.svg)"></span>
                </div>
                <div class="admin-action-item__text">
                    <span class="admin-action-item__title">Создать пользователя</span>
                    <span class="admin-action-item__hint">Добавить нового пользователя и назначить ему роль</span>
                </div>
                <span class="admin-action-item__chevron"></span>
            </a>
        </div>

    </div>
</main>