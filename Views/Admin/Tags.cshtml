@{
    ViewData["Title"] = "Управление тегами";
}

<main class="admin-page">
    <div class="admin-page__inner">

        <!-- Шапка -->
        <div class="admin-header admin-fade-in">
            <div class="admin-header__left">
                <a asp-controller="Admin" asp-action="Index" class="admin-header__back">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                    Панель управления
                </a>
                <h1 class="admin-header__title">Теги</h1>
                <p class="admin-header__subtitle">Категории и метки для фильтрации новостей</p>
            </div>
        </div>

        <div class="admin-divider"></div>

        <!-- Заглушка -->
        <div class="admin-wip admin-fade-in" style="animation-delay:0.1s">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"
                 stroke-linecap="round" stroke-linejoin="round" style="color: var(--mute-color); opacity: 0.45;">
                <path d="M20.59 13.41L13.42 20.58a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z" />
                <line x1="7" y1="7" x2="7.01" y2="7" />
            </svg>
            <p class="admin-wip__title">Раздел в разработке</p>
            <p class="admin-wip__text">
                Управление тегами появится в одном из следующих обновлений.
            </p>
        </div>

    </div>
</main>