@model HsoPkipt.ViewModels.Users.UserItemVM

@{
    ViewData["Title"] = "Удаление пользователя";
}

<main class="admin-page">
    <div class="admin-page__inner">

        <div class="admin-header">
            <h1 class="admin-header__title">Удаление пользователя</h1>
        </div>

        <div class="admin-divider"></div>

        <div class="admin-delete-card">
            <div class="admin-delete-card__body">

                <div class="admin-delete-card__warning">
                    <p>Вы действительно хотите удалить пользователя?</p>
                </div>

                <div class="admin-delete-card__info">
                    <div class="admin-delete-card__row">
                        <span>Email</span>
                        <span>@Model.Email</span>
                    </div>
                    <div class="admin-delete-card__row">
                        <span>Имя</span>
                        <span>@Model.FirstName @Model.LastName</span>
                    </div>
                    <div class="admin-delete-card__row">
                        <span>Роль</span>
                        <span>@Model.Role</span>
                    </div>
                </div>

                <div class="admin-delete-card__actions">
                    <form asp-action="DeleteConfirmed" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="admin-delete-btn">
                            Удалить
                        </button>
                    </form>

                    <a asp-action="Index" asp-controller="AdminUser" class="admin-form__cancel">Отмена</a>
                </div>

            </div>
        </div>

    </div>
</main>