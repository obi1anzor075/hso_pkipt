@model HsoPkipt.ViewModels.Users.UpdateUserVM

@{
    ViewData["Title"] = "Редактирование пользователя";
}

<main class="admin-page">
    <div class="admin-page__inner">

        <div class="admin-header">
            <h1 class="admin-header__title">Редактирование пользователя</h1>
        </div>

        <div class="admin-divider"></div>

        <div class="admin-form-wrap">
            <div class="admin-form-wrap__body">
                <form method="post" class="admin-form">
                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="Id" />

                    <div class="admin-form__field">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" class="admin-form__input" />
                    </div>

                    <div class="admin-form__field">
                        <label asp-for="FirstName">Имя</label>
                        <input asp-for="FirstName" class="admin-form__input" />
                    </div>

                    <div class="admin-form__field">
                        <label asp-for="LastName">Фамилия</label>
                        <input asp-for="LastName" class="admin-form__input" />
                    </div>

                    <div class="admin-form__field">
                        <label asp-for="Position">Должность</label>
                        <input asp-for="Position" class="admin-form__input" />
                    </div>

                    <div class="admin-form__field">
                        <label asp-for="Role">Роль</label>
                        <select asp-for="Role" class="admin-form__input">
                            <option>User</option>
                            <option>Moderator</option>
                            <option>Admin</option>
                        </select>
                    </div>

                    <div class="admin-form__actions">
                        <button type="submit" class="admin-form__submit">
                            Сохранить
                        </button>
                        <a asp-action="Index" asp-controller="AdminUser" class="admin-form__cancel">Отмена</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <script src="~/js/effect/admin-news.edit.js"></script>
}