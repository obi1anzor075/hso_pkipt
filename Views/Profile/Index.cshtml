@model HsoPkipt.ViewModels.Profile.ProfileVM

@{
    ViewData["Title"] = "Профиль";
    var photoUrl = !string.IsNullOrEmpty(Model.ProfilePhoto.CurrentPhotoUrl)
        ? Model.ProfilePhoto.CurrentPhotoUrl
        : Url.Content("~/assets/icon/err.no-image.svg");
}

<main class="profile-page">
    <div class="profile-page__inner">

        <!-- ─── Шапка профиля ─── -->
        <aside class="profile-sidebar">
            <div class="profile-sidebar__avatar-wrap">
                <img src="@photoUrl"
                     alt="Фото профиля"
                     class="profile-sidebar__avatar"
                     id="avatarPreview" />
                <label for="photoInput" class="profile-sidebar__avatar-edit" title="Изменить фото">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                </label>
            </div>

            <div class="profile-sidebar__info">
                <p class="profile-sidebar__name">@Model.ProfileInfo.FirstName @Model.ProfileInfo.LastName</p>
                @if (!string.IsNullOrWhiteSpace(Model.ProfileInfo.Position))
                {
                    <p class="profile-sidebar__position">@Model.ProfileInfo.Position</p>
                }
            </div>

            <nav class="profile-nav">
                <button class="profile-nav__item active" data-tab="info">
                    Основная информация
                </button>
                <button class="profile-nav__item" data-tab="security">
                    Безопасность
                </button>
                <button class="profile-nav__item" data-tab="events">
                    События
                </button>
                <button class="profile-nav__item" data-tab="orders">
                    Заказы
                </button>
            </nav>

            <form asp-action="Logout" asp-controller="Auth" method="post" class="profile-sidebar__logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="profile-sidebar__logout">
                    <span class="profile-sidebar__logout-icon"></span>
                    Выйти из аккаунта
                </button>
            </form>
        </aside>

        <!-- ─── Контент ─── -->
        <div class="profile-content">

            <!-- Уведомления -->
            @if (TempData["ProfileSuccess"] != null)
            {
                <div class="profile-alert profile-alert--success">@TempData["ProfileSuccess"]</div>
            }
            @if (TempData["ProfileError"] != null)
            {
                <div class="profile-alert profile-alert--error">@TempData["ProfileError"]</div>
            }
            @if (TempData["PasswordSuccess"] != null)
            {
                <div class="profile-alert profile-alert--success">@TempData["PasswordSuccess"]</div>
            }
            @if (TempData["PasswordError"] != null)
            {
                <div class="profile-alert profile-alert--error">@TempData["PasswordError"]</div>
            }
            @if (TempData["PhotoSuccess"] != null)
            {
                <div class="profile-alert profile-alert--success">@TempData["PhotoSuccess"]</div>
            }
            @if (TempData["PhotoError"] != null)
            {
                <div class="profile-alert profile-alert--error">@TempData["PhotoError"]</div>
            }

            <!-- ─── Вкладка: Основная информация ─── -->
            <section class="profile-section active" id="tab-info">
                <h2 class="profile-section__title">Основная информация</h2>

                <!-- Загрузка фото (скрытая форма) -->
                <form asp-action="UploadPhoto" method="post" enctype="multipart/form-data" id="photoForm">
                    @Html.AntiForgeryToken()
                    <input asp-for="ProfilePhoto.Photo"
                           type="file"
                           id="photoInput"
                           accept="image/jpeg,image/png,image/webp"
                           class="profile-photo__input" />
                </form>

                <!-- Форма основной информации -->
                <form asp-action="UpdateInfo" method="post" class="profile-form" id="infoForm">
                    @Html.AntiForgeryToken()

                    <div class="profile-form__grid">
                        <div class="profile-form__field profile-form__field--readonly">
                            <label asp-for="ProfileInfo.FirstName" class="profile-form__label">Имя</label>
                            <input asp-for="ProfileInfo.FirstName"
                                   class="profile-form__input"
                                   readonly
                                   tabindex="-1" />
                            <span class="profile-form__readonly-hint">Не редактируется</span>
                        </div>

                        <div class="profile-form__field profile-form__field--readonly">
                            <label asp-for="ProfileInfo.LastName" class="profile-form__label">Фамилия</label>
                            <input asp-for="ProfileInfo.LastName"
                                   class="profile-form__input"
                                   readonly
                                   tabindex="-1" />
                            <span class="profile-form__readonly-hint">Не редактируется</span>
                        </div>

                        <div class="profile-form__field">
                            <label asp-for="ProfileInfo.Email" class="profile-form__label">Электронная почта</label>
                            <input asp-for="ProfileInfo.Email"
                                   class="profile-form__input"
                                   type="email" />
                            <span asp-validation-for="ProfileInfo.Email" class="profile-form__error"></span>
                        </div>

                        <div class="profile-form__field">
                            <label asp-for="ProfileInfo.PhoneNumber" class="profile-form__label">Номер телефона</label>
                            <input asp-for="ProfileInfo.PhoneNumber"
                                   class="profile-form__input"
                                   type="tel" />
                            <span asp-validation-for="ProfileInfo.PhoneNumber" class="profile-form__error"></span>
                        </div>

                        <div class="profile-form__field profile-form__field--full profile-form__field--readonly">
                            <label asp-for="ProfileInfo.Position" class="profile-form__label">Должность</label>
                            <input asp-for="ProfileInfo.Position"
                                   class="profile-form__input"
                                   readonly
                                   tabindex="-1" />
                            <span class="profile-form__readonly-hint">Не редактируется</span>
                        </div>
                    </div>

                    <div class="profile-form__actions">
                        <button type="submit" class="profile-btn profile-btn--primary">
                            Сохранить изменения
                        </button>
                    </div>
                </form>
            </section>

            <!-- ─── Вкладка: Безопасность ─── -->
            <section class="profile-section" id="tab-security">
                <h2 class="profile-section__title">Безопасность</h2>
                <p class="profile-section__subtitle">Смена пароля от аккаунта</p>

                <form asp-action="ChangePassword" method="post" class="profile-form" id="passwordForm">
                    @Html.AntiForgeryToken()

                    <div class="profile-form__grid profile-form__grid--single">

                        <div class="profile-form__field">
                            <label asp-for="ChangePassword.CurrentPassword" class="profile-form__label">
                                Текущий пароль
                            </label>
                            <div class="profile-form__input-wrap">
                                <input asp-for="ChangePassword.CurrentPassword"
                                       type="password"
                                       class="profile-form__input"
                                       id="currentPassword"
                                       autocomplete="current-password" />
                                <button type="button" class="profile-form__eye" data-target="currentPassword">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                            </div>
                            <span asp-validation-for="ChangePassword.CurrentPassword" class="profile-form__error"></span>
                        </div>

                        <div class="profile-form__field">
                            <label asp-for="ChangePassword.NewPassword" class="profile-form__label">
                                Новый пароль
                            </label>
                            <div class="profile-form__input-wrap">
                                <input asp-for="ChangePassword.NewPassword"
                                       type="password"
                                       class="profile-form__input"
                                       id="newPassword"
                                       autocomplete="new-password" />
                                <button type="button" class="profile-form__eye" data-target="newPassword">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                            </div>
                            <span asp-validation-for="ChangePassword.NewPassword" class="profile-form__error"></span>

                            <!-- Индикатор силы пароля -->
                            <div class="password-strength" id="passwordStrength">
                                <div class="password-strength__bar">
                                    <div class="password-strength__fill" id="strengthFill"></div>
                                </div>
                                <span class="password-strength__label" id="strengthLabel"></span>
                            </div>
                            <ul class="password-rules" id="passwordRules">
                                <li class="password-rules__item" data-rule="length">Минимум 8 символов</li>
                                <li class="password-rules__item" data-rule="upper">Заглавная буква</li>
                                <li class="password-rules__item" data-rule="digit">Цифра</li>
                                <li class="password-rules__item" data-rule="special">Специальный символ (!@@#$...)</li>
                            </ul>
                        </div>

                        <div class="profile-form__field">
                            <label asp-for="ChangePassword.ConfirmPassword" class="profile-form__label">
                                Подтверждение пароля
                            </label>
                            <div class="profile-form__input-wrap">
                                <input asp-for="ChangePassword.ConfirmPassword"
                                       type="password"
                                       class="profile-form__input"
                                       id="confirmPassword"
                                       autocomplete="new-password" />
                                <button type="button" class="profile-form__eye" data-target="confirmPassword">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </button>
                            </div>
                            <span asp-validation-for="ChangePassword.ConfirmPassword" class="profile-form__error"></span>
                            <span class="profile-form__match-hint" id="matchHint"></span>
                        </div>

                    </div>

                    <div class="profile-form__actions">
                        <button type="submit" class="profile-btn profile-btn--primary" id="passwordSubmit">
                            Сменить пароль
                        </button>
                    </div>
                </form>
            </section>

            <!-- ─── Вкладка: События ─── -->
            <section class="profile-section" id="tab-events">
                <h2 class="profile-section__title">События</h2>

                <div class="calendar" id="calendar">
                    <!-- Левая панель -->
                    <div class="calendar__sidebar">
                        <div class="calendar__mini" id="calendarMini"></div>
                        <div class="calendar__upcoming" id="calendarUpcoming"></div>
                    </div>
                    <!-- Основная область -->
                    <div class="calendar__main">
                        <div class="calendar__toolbar">
                            <button class="calendar__nav-btn" id="calPrev">&#8249;</button>
                            <div class="calendar__toolbar-center">
                                <span class="calendar__range" id="calRange"></span>
                                <div class="calendar__view-switch">
                                    <button class="calendar__view-btn active" data-view="week">Неделя</button>
                                    <button class="calendar__view-btn" data-view="day">День</button>
                                </div>
                            </div>
                            <button class="calendar__nav-btn" id="calNext">&#8250;</button>
                        </div>
                        <div class="calendar__grid-wrap">
                            <div class="calendar__grid" id="calendarGrid"></div>
                        </div>
                    </div>
                </div>
            </section>

            <section class="profile-section" id="tab-orders">
                <h2 class="profile-section__title">Заказы</h2>

                @if (Model.Orders.Count == 0)
                {
                    <p>У вас пока нет заказов.</p>
                }
                else
                {
                    @foreach (var order in Model.Orders)
                    {
                        <article>
                            <h3>Заказ от @order.CreatedAt.ToString("dd.MM.yyyy HH:mm")</h3>
                            <p>Получатель: @order.RecipientName</p>
                            <p>Телефон: @order.PhoneNumber</p>
                            <p>Адрес: @order.DeliveryAddress</p>
                            <p>Сумма: @order.TotalPrice ₽</p>

                            <table>
                                <thead>
                                    <tr>
                                        <th>Товар</th>
                                        <th>Цена</th>
                                        <th>Количество</th>
                                        <th>Сумма</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in order.Items)
                                    {
                                        <tr>
                                            <td>@item.Name</td>
                                            <td>@item.Price ₽</td>
                                            <td>@item.Quantity</td>
                                            <td>@item.TotalPrice ₽</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </article>
                    }
                }
            </section>

        </div>
    </div>
</main>

<!-- ─── Плавающий баннер превью фото ─── -->
<div class="photo-banner" id="photoBanner" aria-hidden="true">
    <div class="photo-banner__inner">
        <img src="" alt="Превью фото" class="photo-banner__img" id="photoBannerImg" />
        <div class="photo-banner__text">
            <p class="photo-banner__title">Новое фото профиля</p>
            <p class="photo-banner__hint" id="photoBannerHint">Выглядит хорошо?</p>
        </div>
        <div class="photo-banner__actions">
            <button type="button" class="profile-btn profile-btn--primary" id="photoConfirmBtn">
                Сохранить
            </button>
            <button type="button" class="profile-btn profile-btn--ghost photo-banner__cancel" id="photoCancelBtn">
                Отмена
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.profileEvents = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                Model.UpcomingEvents
                    .Where(e => e.IsPublished)
                    .Select(e => new {
                    id = e.Id,
                    title = e.Title,
                    description = e.Description,
                    date = e.Date.ToString("yyyy-MM-ddTHH:mm:ss")
                })
            )
        );
    </script>
    <script src="~/js/app/profile.index.js"></script>
    <script src="~/js/effect/profile.index.js"></script>
}
