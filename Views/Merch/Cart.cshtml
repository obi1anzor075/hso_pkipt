@model HsoPkipt.ViewModels.Merch.MerchCartVM

@{
    ViewData["Title"] = "Корзина";
}

<main class="shop shop--cart">
    <section class="shop__hero">
        <div class="shop__hero-inner">
            <h1 class="shop__title">Корзина</h1>
            <p class="shop__subtitle">Проверьте товары перед оформлением</p>
        </div>
    </section>

    <div class="shop__container">
        <section class="shop__products shop__products--wide">
            @if (Model.IsEmpty)
            {
                <div class="shop-cart-empty">
                    <p>Корзина пока пустая.</p>
                    <a asp-action="Index" class="shop__cart-link">Вернуться к мерчу</a>
                </div>
            }
            else
            {
                <div class="shop-cart-list">
                    @foreach (var item in Model.Items)
                    {
                        <article class="shop-cart-item">
                            <div class="shop-cart-item__media">
                                <img src="@(string.IsNullOrWhiteSpace(item.ImageUrl) ? Url.Content("~/assets/icon/err.no-image.svg") : item.ImageUrl)" alt="@item.Name" />
                            </div>

                            <div class="shop-cart-item__content">
                                <div class="shop-cart-item__head">
                                    <h2>@item.Name</h2>
                                    <div class="shop-cart-item__price">@item.Price ₽</div>
                                </div>

                                <div class="shop-cart-item__controls">
                                    <form method="post" asp-action="UpdateCartItem" class="shop-cart-item__quantity">
                                        <input type="hidden" name="merchItemId" value="@item.Id" />
                                        <label>
                                            Количество
                                            <input type="number" name="quantity" min="1" value="@item.Quantity" />
                                        </label>
                                        <button type="submit">Обновить</button>
                                    </form>

                                    <form method="post" asp-action="RemoveFromCart">
                                        <input type="hidden" name="merchItemId" value="@item.Id" />
                                        <button type="submit" class="shop-cart-item__remove">Удалить</button>
                                    </form>
                                </div>
                            </div>

                            <div class="shop-cart-item__total">
                                @item.TotalPrice ₽
                            </div>
                        </article>
                    }
                </div>

                <aside class="shop-cart-summary-panel">
                    <div class="shop-cart-summary-panel__row">
                        <span>Товаров</span>
                        <strong>@Model.ItemsCount</strong>
                    </div>
                    <div class="shop-cart-summary-panel__row">
                        <span>Итого</span>
                        <strong>@Model.TotalPrice ₽</strong>
                    </div>
                    <a asp-action="Index" class="shop__cart-link">Продолжить покупки</a>
                    <form method="post" asp-action="ClearCart">
                        <button type="submit" class="shop-cart-summary-panel__clear">Очистить корзину</button>
                    </form>
                </aside>
            }
        </section>
    </div>
</main>
