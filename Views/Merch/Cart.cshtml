@model HsoPkipt.ViewModels.Merch.MerchCartPageVM

@{
    ViewData["Title"] = "Корзина";
}

<main class="cart-page">
    <div class="cart-page__inner">

        <!-- Шапка -->
        <div class="cart-header">
            <div class="cart-header__left">
                <a asp-action="Index" class="cart-header__back">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                    Вернуться в каталог
                </a>
                <h1 class="cart-header__title">Корзина</h1>
                @if (!Model.Cart.IsEmpty)
                {
                    <p class="cart-header__count">@Model.Cart.ItemsCount позиций</p>
                }
            </div>
        </div>

        <!-- Алерты -->
        @if (TempData["CartSuccess"] != null)
        {
            <div class="cart-alert cart-alert--success">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                </svg>
                @TempData["CartSuccess"]
            </div>
        }
        @if (TempData["CartError"] != null)
        {
            <div class="cart-alert cart-alert--error">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10" />
                    <line x1="12" y1="8" x2="12" y2="12" />
                    <line x1="12" y1="16" x2="12.01" y2="16" />
                </svg>
                @TempData["CartError"]
            </div>
        }

        @if (Model.Cart.IsEmpty)
        {
            <!-- Пустая корзина -->
            <div class="cart-empty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="9" cy="21" r="1" />
                    <circle cx="20" cy="21" r="1" />
                    <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57L23 6H6" />
                </svg>
                <p class="cart-empty__title">Корзина пуста</p>
                <p class="cart-empty__text">Добавьте товары из каталога мерча</p>
                <a asp-action="Index" class="cart-empty__btn">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline style="color: whitesmoke" points="15 18 9 12 15 6" />
                    </svg>
                    Перейти в каталог
                </a>
            </div>
        }
        else
        {
            <!-- Список товаров -->
            <div class="cart-items" id="cartItems">
                @foreach (var item in Model.Cart.Items)
                {
                    <div class="cart-item">
                        <div class="cart-item__img-wrap">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" loading="lazy" />
                            }
                            else
                            {
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                                    <circle cx="8.5" cy="8.5" r="1.5" />
                                    <polyline points="21 15 16 10 5 21" />
                                </svg>
                            }
                        </div>

                        <div class="cart-item__info">
                            <p class="cart-item__name">@item.Name</p>
                            <p class="cart-item__price">@item.Price ₽ за шт.</p>
                        </div>

                        <!-- Счётчик количества -->
                        <div class="cart-item__qty" data-item-id="@item.Id">
                            <button type="button" class="cart-item__qty-btn"
                                    data-qty-dec data-item-id="@item.Id"
                                    @(item.Quantity <= 1 ? "disabled" : "")>
                                −
                            </button>
                            <span class="cart-item__qty-val" data-qty-val="@item.Id">@item.Quantity</span>
                            <button type="button" class="cart-item__qty-btn"
                                    data-qty-inc data-item-id="@item.Id">
                                +
                            </button>
                        </div>

                        <p class="cart-item__total" data-item-total="@item.Id">@item.TotalPrice ₽</p>

                        <!-- Форма удаления -->
                        <form method="post" asp-action="RemoveFromCart" style="display:contents">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="merchItemId" value="@item.Id" />
                            <button type="submit" class="cart-item__remove" title="Удалить">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6" />
                                    <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
                                    <path d="M10 11v6M14 11v6" />
                                    <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
                                </svg>
                            </button>
                        </form>

                        <!-- Скрытая форма обновления количества (управляется JS) -->
                        <form method="post" asp-action="UpdateCartItem"
                              class="cart-item__update-form" data-update-form="@item.Id"
                              style="display:none">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="merchItemId" value="@item.Id" />
                            <input type="hidden" name="quantity" data-qty-input="@item.Id" value="@item.Quantity" />
                        </form>
                    </div>
                }
            </div>

            <!-- Итого + очистить -->
            <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:16px;">
                <form method="post" asp-action="ClearCart">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="cart-clear-btn">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="3 6 5 6 21 6" />
                            <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" />
                            <path d="M10 11v6M14 11v6" />
                            <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" />
                        </svg>
                        Очистить корзину
                    </button>
                </form>

                <div class="cart-summary">
                    <div class="cart-summary__box">
                        <div class="cart-summary__row">
                            <span class="cart-summary__label">Позиций:</span>
                            <span class="cart-summary__val">@Model.Cart.ItemsCount шт.</span>
                        </div>
                        <div class="cart-summary__row cart-summary__row--total">
                            <span class="cart-summary__total-label">Итого:</span>
                            <span class="cart-summary__total-val" id="cartTotal">@Model.Cart.TotalPrice ₽</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Оформление заказа -->
            @if (Model.IsAuthenticated)
            {
                <div class="cart-checkout">
                    <div class="cart-checkout__stripe"></div>
                    <div class="cart-checkout__body">
                        <h2 class="cart-checkout__title">Оформление заказа</h2>
                        <form method="post" asp-action="Checkout" class="cart-checkout__form">
                            @Html.AntiForgeryToken()

                            <div class="cart-checkout__field">
                                <label asp-for="Checkout.RecipientName">Получатель</label>
                                <input asp-for="Checkout.RecipientName" placeholder="Иванов Иван Иванович" />
                                <span asp-validation-for="Checkout.RecipientName" class="cart-checkout__error"></span>
                            </div>

                            <div class="cart-checkout__field">
                                <label asp-for="Checkout.PhoneNumber">Телефон</label>
                                <input asp-for="Checkout.PhoneNumber" placeholder="+7 (999) 000-00-00" type="tel" />
                                <span asp-validation-for="Checkout.PhoneNumber" class="cart-checkout__error"></span>
                            </div>

                            <div class="cart-checkout__field">
                                <label asp-for="Checkout.DeliveryAddress">Адрес доставки</label>
                                <textarea asp-for="Checkout.DeliveryAddress"
                                          placeholder="г. Пенза, ул. Примерная, д. 1, кв. 1"></textarea>
                                <span asp-validation-for="Checkout.DeliveryAddress" class="cart-checkout__error"></span>
                            </div>

                            <button type="submit" class="cart-checkout__submit">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline style="color: whitesmoke" points="20 6 9 17 4 12" />
                                </svg>
                                Оформить заказ
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <div class="cart-login-hint">
                    <p class="cart-login-hint__text">Для оформления заказа необходимо войти в аккаунт</p>
                    <a asp-controller="Auth" asp-action="Login" class="cart-login-hint__btn">
                        <img src="/assets/icon/login.svg" alt="login" width="16" height="16" style="color: whitesmoke" />
                        Войти в аккаунт
                    </a>
                </div>
            }
        }

    </div>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/app/merch.cart.js"></script>
    <script src="~/js/effect/merch.cart.js"></script>
}
