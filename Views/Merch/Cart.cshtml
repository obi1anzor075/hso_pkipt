@model HsoPkipt.ViewModels.Merch.MerchCartPageVM

@{
    ViewData["Title"] = "Корзина";
}

<main>
    <h1>Корзина</h1>

    @if (TempData["CartSuccess"] != null)
    {
        <p>@TempData["CartSuccess"]</p>
    }

    @if (TempData["CartError"] != null)
    {
        <p>@TempData["CartError"]</p>
    }

    @if (Model.Cart.IsEmpty)
    {
        <p>Корзина пуста.</p>
        <p>
            <a asp-action="Index">Вернуться к товарам</a>
        </p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Товар</th>
                    <th>Цена</th>
                    <th>Количество</th>
                    <th>Сумма</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Cart.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price ₽</td>
                        <td>
                            <form method="post" asp-action="UpdateCartItem">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="merchItemId" value="@item.Id" />
                                <input type="number" name="quantity" min="1" value="@item.Quantity" />
                                <button type="submit">Обновить</button>
                            </form>
                        </td>
                        <td>@item.TotalPrice ₽</td>
                        <td>
                            <form method="post" asp-action="RemoveFromCart">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="merchItemId" value="@item.Id" />
                                <button type="submit">Удалить</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <p>Итого: @Model.Cart.TotalPrice ₽</p>

        <form method="post" asp-action="ClearCart">
            @Html.AntiForgeryToken()
            <button type="submit">Очистить корзину</button>
        </form>

        @if (Model.IsAuthenticated)
        {
            <h2>Оформление заказа</h2>

            <form method="post" asp-action="Checkout">
                @Html.AntiForgeryToken()
                <div>
                    <label asp-for="Checkout.RecipientName">Получатель</label>
                    <input asp-for="Checkout.RecipientName" />
                    <span asp-validation-for="Checkout.RecipientName"></span>
                </div>

                <div>
                    <label asp-for="Checkout.PhoneNumber">Телефон</label>
                    <input asp-for="Checkout.PhoneNumber" />
                    <span asp-validation-for="Checkout.PhoneNumber"></span>
                </div>

                <div>
                    <label asp-for="Checkout.DeliveryAddress">Адрес доставки</label>
                    <textarea asp-for="Checkout.DeliveryAddress"></textarea>
                    <span asp-validation-for="Checkout.DeliveryAddress"></span>
                </div>

                <button type="submit">Оформить заказ</button>
            </form>
        }
        else
        {
            <p>
                Для оформления заказа нужно
                <a asp-controller="Auth" asp-action="Login">войти в аккаунт</a>.
            </p>
        }
    }
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
