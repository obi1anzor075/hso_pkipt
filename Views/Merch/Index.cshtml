@model HsoPkipt.ViewModels.Merch.MerchCatalogVM

@{
    ViewData["Title"] = "Мерч";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<main>
    <h1>Мерч</h1>

    <form method="get" asp-action="Search">
        <input type="text" name="q" value="@Model.SearchQuery" placeholder="Поиск..." />
        <button type="submit">Найти</button>
    </form>

    <p>
        Корзина:
        @if (Model.Cart.IsEmpty)
        {
            <span>пусто</span>
        }
        else
        {
            <span>@Model.Cart.ItemsCount шт. на сумму @Model.Cart.TotalPrice ₽</span>
            <a asp-action="Cart">Открыть корзину</a>
        }
    </p>

    @if (Model.Items.Count == 0)
    {
        <p>Товары не найдены.</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Товар</th>
                    <th>Цена</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>
                            <div>@item.Name</div>
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <div>
                                    <img src="@item.ImageUrl" alt="@item.Name" width="120" />
                                </div>
                            }
                        </td>
                        <td>@item.Price ₽</td>
                        <td>
                            <form method="post" asp-action="AddToCart">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="merchItemId" value="@item.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit">Добавить в корзину</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</main>
