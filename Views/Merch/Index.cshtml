@model HsoPkipt.ViewModels.Merch.MerchCatalogVM

@{
    ViewData["Title"] = "Мерч";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    bool hasSearch = !string.IsNullOrWhiteSpace(Model.SearchQuery);
}

<main class="merch-page">
    <div class="merch-page__inner">

        <!-- Шапка -->
        <div class="merch-header">
            <div class="merch-header__left">
                <h1 class="merch-header__title">Мерч ШСО</h1>
                <p class="merch-header__sub">
                    @if (hasSearch)
                    {
                        <span>Результаты поиска по запросу «@Model.SearchQuery»</span>
                    }
                    else
                    {
                        <span>Фирменная атрибутика студенческих отрядов</span>
                    }
                </p>
            </div>

            @if (Model.Cart.IsEmpty)
            {
                <span class="merch-cart-pill empty">
                    <span class="merch-cart-pill__icon"></span>
                    <span class="merch-cart-pill__text">Корзина пуста</span>
                </span>
            }
            else
            {
                <a asp-action="Cart" class="merch-cart-pill">
                    <span class="merch-cart-pill__icon"></span>
                    <span class="merch-cart-pill__text">@Model.Cart.TotalPrice ₽</span>
                    <span class="merch-cart-pill__badge">@Model.Cart.ItemsCount</span>
                </a>
            }
        </div>

        <!-- Поиск -->
        <form method="get" asp-action="Search" class="merch-search">
            <div class="merch-search__input-wrap">
                <span class="merch-search__icon"></span>
                <input type="text" name="q" value="@Model.SearchQuery"
                       class="merch-search__input" placeholder="Поиск по названию…" autocomplete="off" />
            </div>
            <button type="submit" class="merch-search__btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle style="color: whitesmoke" cx="11" cy="11" r="8" />
                    <line style="color: whitesmoke" x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                Найти
            </button>
            @if (hasSearch)
            {
                <a asp-action="Index" class="merch-search__clear">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                    Сбросить
                </a>
            }
        </form>

        <!-- Каталог -->
        @if (Model.Items.Count == 0)
        {
            <div class="merch-empty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    <line x1="11" y1="8" x2="11" y2="14" />
                    <line x1="8" y1="11" x2="14" y2="11" />
                </svg>
                <p class="merch-empty__title">
                    @(hasSearch ? "Ничего не найдено" : "Товары пока не добавлены")
                </p>
                <p class="merch-empty__text">
                    @(hasSearch ? $"По запросу «{Model.SearchQuery}» товаров не найдено" : "Скоро здесь появится атрибутика ШСО")
                </p>
                @if (hasSearch)
                {
                    <a asp-action="Index" class="merch-empty__link">
                        Смотреть весь мерч
                    </a>
                }
            </div>
        }
        else
        {
            <div class="merch-grid">
                @foreach (var item in Model.Items)
                {
                    <div class="merch-card">
                        <div class="merch-card__img-wrap">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" class="merch-card__img" loading="lazy" />
                            }
                            else
                            {
                                <div class="merch-card__no-img">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                                        <circle cx="8.5" cy="8.5" r="1.5" />
                                        <polyline points="21 15 16 10 5 21" />
                                    </svg>
                                </div>
                            }
                        </div>
                        <div class="merch-card__body">
                            <p class="merch-card__name">@item.Name</p>
                            <p class="merch-card__price">
                                @item.Price ₽<span class="merch-card__price-label">/ шт.</span>
                            </p>
                            <form method="post" asp-action="AddToCart">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="merchItemId" value="@item.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="merch-card__btn" data-add-btn>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle style="color: whitesmoke" cx="9" cy="21" r="1" />
                                        <circle style="color: whitesmoke" cx="20" cy="21" r="1" />
                                        <path style="color: whitesmoke" d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57L23 6H6" />
                                    </svg>
                                    В корзину
                                </button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</main>

<!-- Уведомление -->
<div class="merch-toast" id="merchToast"></div>

@section Scripts {
    <script src="~/js/effect/merch.index.js"></script>
    <script src="~/js/app/merch.index.js"></script>
}
